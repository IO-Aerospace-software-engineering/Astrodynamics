<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <ImplicitUsings>disable</ImplicitUsings>
        <Nullable>disable</Nullable>
        <AssemblyName>IO.Astrodynamics.Net</AssemblyName>
        <Company>IO Aerospace</Company>
        <LangVersion>12</LangVersion>
        <!-- Suppress CS8981 for auto-generated PDS model classes with lowercase type names -->
        <NoWarn>$(NoWarn);CS8981</NoWarn>
        <TargetFramework>net10.0</TargetFramework>

        <!-- NuGet package metadata (replaces IO.Astrodynamics.nuspec) -->
        <PackageId>IO.Astrodynamics</PackageId>
        <Version>9.0.0-preview-4</Version>
        <Authors>Sylvain Guillet</Authors>
        <Copyright>Sylvain Guillet</Copyright>
        <Title>IO Astrodynamics framework</Title>
        <Description>This astrodynamics framework provides tools to manipulate orbital parameters, run spacecraft propagation, evaluate impulsive maneuvers, generate fuel balance, compute spacecraft attitudes (prograde, nadir, normal, TRIAD with orbital/celestial targets), ...</Description>
        <PackageTags>astrodynamics aerospace orbital mechanics spice space physics attitude</PackageTags>
        <PackageProjectUrl>https://github.com/IO-Aerospace-software-engineering/Astrodynamics</PackageProjectUrl>
        <PackageLicenseExpression>LGPL-3.0-or-later</PackageLicenseExpression>
        <PackageIcon>dragonfly-dark-trans.png</PackageIcon>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="IO.Astrodynamics.Tests" />
        <InternalsVisibleTo Include="IO.Astrodynamics.CLI.Tests" />
        <InternalsVisibleTo Include="IO.Astrodynamics.Pro" />
    </ItemGroup>
    <PropertyGroup>
        <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net7.0'))">true</IsAotCompatible>
    </PropertyGroup>

    <ItemGroup>
        <None Remove="resources\libIO.SDK.so" />
    </ItemGroup>

    <ItemGroup>
        <None Remove="resources\IO.SDK.dll" />
        <None Remove="resources\IO.SDK.exp" />
        <None Remove="resources\IO.SDK.lib" />
    </ItemGroup>

    <ItemGroup>
      <EmbeddedResource Include="Templates\InstrumentFrameTemplate.tf" />
      <EmbeddedResource Include="Templates\InstrumentKernelCircularTemplate.ti" />
      <EmbeddedResource Include="Templates\InstrumentKernelEllipticalTemplate.ti" />
      <EmbeddedResource Include="Templates\InstrumentKernelRectangularTemplate.ti" />
      <EmbeddedResource Include="Templates\SiteFrameTemplate.tf" />
      <None Remove="PDS\V4\Schemas\PDS4_MSN_1K00_1300.xsd" />
      <EmbeddedResource Include="PDS\V4\Schemas\PDS4_MSN_1K00_1300.xsd" />
      <None Remove="PDS\V4\Schemas\PDS4_PDS_1K00.xsd" />
      <EmbeddedResource Include="PDS\V4\Schemas\PDS4_PDS_1K00.xsd" />
      <None Remove="PDS\V4\Schemas\PDS4_PDS_1K00.JSON" />
      <None Remove="PDS\V4\Schemas\PDS4_MSN_1K00_1300.JSON" />
      <None Remove="PDS\V4\Schemas\PDS4_MSN_SURFACE_1K00_1220.xsd" />
      <EmbeddedResource Include="PDS\V4\Schemas\PDS4_MSN_SURFACE_1K00_1220.xsd">
        <CopyToOutputDirectory>Never</CopyToOutputDirectory>
      </EmbeddedResource>
    </ItemGroup>

    <ItemGroup>
      <None Remove="resources\One_Sgp4.dll" />
      <!-- Native libs: copy to output for local dev + pack into runtimes/ for NuGet -->
      <Content Include="resources\IO.Astrodynamics.dll" Pack="true" PackagePath="runtimes/windows10-x64/">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
      <Content Include="resources\IO.Astrodynamics.lib" Pack="true" PackagePath="runtimes/windows10-x64/">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
      <Content Include="resources\libIO.Astrodynamics.so" Pack="true" PackagePath="runtimes/linux-x64/">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
      <None Remove="resources\io-only-dark.png" />
      <Content Include="resources\io-only-dark.png">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
    </ItemGroup>

    <!-- NuGet package content: .targets, icon, readme -->
    <ItemGroup>
      <None Include="IO.Astrodynamics.targets" Pack="true" PackagePath="build/" />
      <None Include="..\..\README.md" Pack="true" PackagePath="/" />
    </ItemGroup>

    <ItemGroup>
      <None Remove="Templates\FrameTemplate.tf" />
      <EmbeddedResource Include="Templates\ClockTemplate.tsc" />
      <EmbeddedResource Include="Templates\FrameTemplate.tf" />
    </ItemGroup>

    <ItemGroup>
      <Compile Remove="Math\VectorExtension.cs" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="MathNet.Filtering.Kalman" Version="0.7.0" />
      <PackageReference Include="MathNet.Numerics" Version="5.0.0" />
    </ItemGroup>

    <ItemGroup>
      <!-- CCSDS NDM/XML Schemas (embedded resources for validation) -->
      <EmbeddedResource Include="CCSDS\Schema\ndmxml-4.0.0-common-4.0.xsd" />
      <EmbeddedResource Include="CCSDS\Schema\ndmxml-4.0.0-omm-3.0.xsd" />
      <EmbeddedResource Include="CCSDS\Schema\ndmxml-4.0.0-opm-3.0.xsd" />
      <EmbeddedResource Include="CCSDS\Schema\ndmxml-4.0.0-oem-3.0.xsd" />
      <EmbeddedResource Include="CCSDS\Schema\ndmxml-4.0.0-aem-2.0.xsd" />
      <EmbeddedResource Include="CCSDS\Schema\ndmxml-4.0.0-apm-2.0.xsd" />
      <EmbeddedResource Include="CCSDS\Schema\ndmxml-4.0.0-cdm-1.0.xsd" />
      <EmbeddedResource Include="CCSDS\Schema\ndmxml-4.0.0-tdm-2.0.xsd" />
      <EmbeddedResource Include="CCSDS\Schema\ndmxml-4.0.0-rdm-1.0.xsd" />
      <EmbeddedResource Include="CCSDS\Schema\ndmxml-4.0.0-ndm-4.0.xsd" />
      <EmbeddedResource Include="CCSDS\Schema\ndmxml-4.0.0-master-4.0.xsd" />
      <EmbeddedResource Include="CCSDS\Schema\ndmxml-4.0.0-namespace-4.0.xsd" />
      <EmbeddedResource Include="CCSDS\Schema\ndmxml-4.0.0-acm-2.0.xsd" />
      <EmbeddedResource Include="CCSDS\Schema\ndmxml-4.0.0-ocm-3.0.xsd" />
    </ItemGroup>

</Project>
